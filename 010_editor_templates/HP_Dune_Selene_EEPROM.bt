//------------------------------------------------
// HP Dune/Selene Platform — M24256BW EEPROM Template
// 010 Editor Binary Template
//
// Firmware: 6.17.5.40-202503181735
// EEPROM:   M24256BW I2C (32 KB, 512 pages x 64 bytes)
// Platform: ARM v7 (BE8 bootloader, LE kernel)
//
// Reverse-engineered from dune_selene_nandboot.bin,
// dune_selene_kexec_trusted_fw.bin (bootloaders),
// and kernel_6.17.elf (Linux kernel NVM driver).
//
// Three-tier system architecture (system-wide view):
//   Tier 1: Bootloader partitioned fields (0x000-0x0C1)
//   Tier 2: Bootloader flat fields          (0x100-0x130)
//   Tier 3: Kernel NVM object storage       (0x2C0+)
//
// The NOS region (0x000-0x1FD) has its own internal
// three-tier partitioning in the firmware_toolkit codec
// (not to be confused with the system view above):
//   NOS Tier-1: partitioned fields          (0x000-0x0C1)
//   NOS Tier-2: bootloader flat fields      (0x100-0x130)
//   NOS Tier-3: NOS NVM extension           (0x131-0x1FD)
//                - backup_device_pin  @0x131 (4 B, NVM ID 0x94)
//                - nos_nvm_reserved   @0x135 (201 B, 0xFF filler)
//
// Bootloader field layout from type 0x40 sub-partition
// table at binary address 0x9FF33AA4 (21 entries).
// Kernel NVM layout from _nvm_build_table decompilation.
//
// ---------------------------------------------------------
// Write-path / backup / torn-write model (firmware 6.28.1.47)
// ---------------------------------------------------------
// See documentation_current/NVM2_Write_Path.md for details.
// Summary:
//
//   Userspace → kernel framing on write(/dev/eeprom, …):
//     0x46 'F'  set/upsert : [0x46 | var_id:LE2 | vendor_id:LE2 | ciphertext:1..512]
//     0x44 'D'  delete     : [0x44 | var_id:LE2 | vendor_id:LE2 | 0x44]  (6 bytes)
//     0x52 'R'  recovery/raw (kernel-internal)
//   Ciphertext is produced by NVRamEEPROM::encodeData() in libNvram.so
//   BEFORE the write() — the kernel stores only ciphertext for v=2.
//
//   Kernel allocator (kernel.elf _nvm_allocate / _delete_object):
//     - Packed, not append-only: first-fit into pages starting at page 11.
//     - Multi-page spans: alloc_bits[p..p+k]=1, span_bits[p+1..p+k]=1.
//     - Delete compacts via memmove() and clears bitmap bits on empty pages.
//     - Unused tail of an allocated page is 0xFF fill; no in-storage
//       end-of-record sentinel tag.
//
//   Per-record integrity:
//     - Journal bit lives inside the stored object_id and is set during
//       a destructive change, cleared on commit. _nvm_build_table drops
//       journalled copies on boot if a non-journalled duplicate exists.
//     - NO per-record CRC / MAC anywhere in the NVM2 region. CRC32 in
//       libNvram.so is only a name→id hash; SHA-256 is only in the
//       backup-file layer (HP_Dune_Selene_Backup_Encryption.md).
//
//   Image backup (RedundancyNvramEEPROM, libNvram.so 0x31860 doValidateOperate):
//     Primary  : /mnt/rw/backups/eeprom.bak        (text metadata header +
//                                                   AES-wrapped 32 KB image;
//                                                   envelope per
//                                                   HP_Dune_Selene_Backup_Encryption.md)
//     Staging  : /mnt/rw/backups/eeprom.bak.part   (atomic rename target)
//     Directory: /mnt/rw/backups/                  (auto-created by setupBackup)
//
//   Reconciliation state machine (runs ONCE per boot, at framework NVRAM-
//   stack init; NOT per write, NOT on a timer):
//     1. setupBackup()                -> ensure dir exists
//     2. validateResetMetaData()      -> remove() stale backup if Reset-Mark
//                                        is not 3 or 5
//     3. validateOperationMetaData(recoveryCount) returns:
//           1  if  recoveryCount == 0                      (fresh boot)
//                  OR backup missing / unparseable
//                  OR stored Recovery-Count == recoveryCount
//                   -> doUploadData  (live EEPROM -> backup, refresh)
//           2  if  stored Recovery-Count != recoveryCount
//                   -> doDownloadData (backup -> live EEPROM, restore)
//           3  (rare/external path)
//                   -> doResetData    (ioctl 0x800465c9, _format_nvm)
//
//   Precedence: the recovery-count (== NVM2 format_count @ 0x211) is the
//   sole arbiter. Equal  -> trust live, refresh backup. Unequal  -> trust
//   backup, restore it. NO byte-by-byte compare.
//
//   Bulk-image ioctls bracketed with key install/release:
//     0x8004656f  install 32-B key (from kernel keyring, secretKeyDiscovery)
//     0x8004656c  bulk read  0x8000 B  (upload : live -> userspace buffer)
//     0x8004656e  bulk write 0x8000 B  (download: buffer -> live, SHA-256 checked)
//     0x80046570  release key
//     0x800465c9  format NVM (reset path)
//
//   CONSEQUENCE FOR OUT-OF-BAND FLASHING:
//   When reflashing the EEPROM image, ALSO delete /mnt/rw/backups/eeprom.bak.
//   Otherwise on the next boot, if the stored backup's Recovery-Count does
//   not match the flashed image's format_count, doDownloadData will silently
//   restore the stale pre-flash image on top of the fresh one.
//
// For a byte-identical round-trip encoder:
//   preserve record page/offsets, bitmaps and format_count verbatim;
//   re-XOR the Layer-1 keystream onto the plaintext; pad 0xFF; never
//   set the journal bit; erase /mnt/rw/backups/eeprom.bak when reflashing.
//------------------------------------------------

LittleEndian();

//------------------------------------------------
// Color definitions
//------------------------------------------------
local int cControl     = 0xFFE4B5;  // moccasin
local int cInternal    = 0xD3D3D3;  // light gray
local int cField       = 0xADD8E6;  // light blue
local int cMirror      = 0xFFA07A;  // light salmon
local int cChecksum    = 0xFF6347;  // tomato
local int cSerial      = 0xFFD700;  // gold
local int cCounter     = 0xFFB6C1;  // light pink
local int cFlatField   = 0x98FB98;  // pale green
local int cNVM2Header  = 0xDDA0DD;  // plum
local int cBitmap      = 0xB0C4DE;  // light steel blue
local int cNVMObject   = 0xFFA500;  // orange
local int cMAC         = 0x90EE90;  // light green
local int cPadding     = 0xD3D3D3;  // light gray
local int cDynGap      = 0xE8E8E8;  // lighter gray
local int cNosNvmExt   = 0xBFEFFF;  // pale cyan (NOS NVM extension tier-3)
local int cRootPtr     = 0xDDA0DD;  // plum (matches NVM2 header)

//------------------------------------------------
// Protection type enum
//------------------------------------------------
typedef enum <ubyte> {
    PROT_MIRROR_CHECKSUM     = 0,  // primary + mirror(XOR 0xFF) + checksum (2N+1)
    PROT_PRIMARY_ONLY        = 1,  // primary only (N)
    PROT_MIRROR_ONLY         = 2,  // primary + mirror(XOR 0xFF) (2N)
    PROT_MIRROR_CHECKSUM_ALT = 3,  // same as 0, different checksum seed (2N+1)
} PROT_TYPE;

//------------------------------------------------
// NVM2 Vendor IDs (TLV tag byte, top 8 bits of the
// 24-bit object ID).
//
// The tag indexes into libNvram.so's dispatch table
// at ELF offset 0x68b2c (Ghidra 0x78b2c) — 6 entries
// of {Uuid* GUIDE_ptr, uint32 tag}. Each GUIDE points
// to a 16-byte Uuid global defined in libframework.so
// and runtime-initialised by its _INIT_24 constructor
// (@Ghidra 0x12da00) via Uuid::fromChars(guide, uuid_str).
//
// The Layer-1 XOR key derivation for v=2 and for
// non-v2 tags is identical:
//   k_name = SHA256(vendor_uuid_36char_str || varname)
//   key_stripe[i] = k_name[i%32] XOR DUID[i%32]
// Only the UUID input string differs per-tag.
//
// Confirmed mappings (firmware 6.28.1.47):
//   tag 0x01 -> HP_DUNE_NUMERIC_GUIDE
//              "4e565241-4d5f-5355-4944-5f5641525300"
//              (ASCII: "NVRAM_SUID_VARS\x00")
//   tag 0x02 -> HP_DUNE_SETTINGS_GUIDE
//              "48505f44-554e-455f-5345-5454494e4753"
//              (ASCII: "HP_DUNE_SETTINGS")
//   tag 0x03 -> BIOS_SETTINGS_GUIDE
//              "845e3285-c67c-4f4b-9aa4-0ae91bd35089"
//   tag 0x04 -> DEVICE_CONFIG_GUIDE
//              "0429e79e-d9ba-412e-a2bc-1f3d245041ce"
//   tag 0x05 -> DEVICE_INFO_GUIDE
//              "1429e79e-d9ba-412e-a2bc-1f3d245041ce"
//   tag 0x0a -> NVRAM_LOCAL_TEST_GUIDE
//              "4e565241-4d5f-4c4f-4341-4c5f54455354"
//              (ASCII: "NVRAM_LOCAL_TEST")
//
// Tags not in the libframework GUIDE dispatch
// (handled by separate code paths / legacy writers):
//   tag 0x06 -> MAC/power-cycle namespace (WLAN0/WLAN1
//              MAC, POWER_CYCLE_COUNT) — not routed
//              through the v=2 crypto, flat fields
//   tag 0x14 -> bootloader BOOT_FLAGS alt namespace
//
// Vendor 2 (HP_DUNE_SETTINGS) dominates the dump and
// holds all crypto-sensitive Region-B variables
// (DefaultDevicePin, BackupDevicePin, counters, etc.).
//------------------------------------------------
typedef enum <ubyte> {
    NVM_VENDOR_HP_DUNE_NUMERIC  = 0x01,  // HP_DUNE_NUMERIC_GUIDE / NVRAM_SUID_VARS (small numeric IDs, e.g. DefaultDevicePin-alt 0x01 format)
    NVM_VENDOR_HP_DUNE_SETTINGS = 0x02,  // HP_DUNE_SETTINGS_GUIDE (Layer-1 XOR encrypted, majority of dump)
    NVM_VENDOR_BIOS_SETTINGS    = 0x03,  // BIOS_SETTINGS_GUIDE (CfgRuntimeProduct/CfgDerivative-class)
    NVM_VENDOR_DEVICE_CONFIG    = 0x04,  // DEVICE_CONFIG_GUIDE (MAP_REVISION/PSKU-class)
    NVM_VENDOR_DEVICE_INFO      = 0x05,  // DEVICE_INFO_GUIDE (device identity)
    NVM_VENDOR_WLAN_MAC         = 0x06,  // WLAN0/WLAN1 MAC, POWER_CYCLE_COUNT (NOT a libframework GUIDE)
    NVM_VENDOR_NVRAM_LOCAL_TEST = 0x0a,  // NVRAM_LOCAL_TEST_GUIDE (ETH0 MAC piggybacks here in some builds)
    NVM_VENDOR_BOOT_FLAGS_ALT   = 0x14,  // BOOT_FLAGS alt namespace (NOT a libframework GUIDE)
} NVM_VENDOR_ID;

//------------------------------------------------
// SECTION 1: NVM Partitioned Field Region (0x000–0x0C1)
//
// Layout defined by type 0x40 sub-partition table.
// Offsets computed by accumulating entry sizes:
//   0x00(1) 0x17(4) 0x01(1) 0x0A(2) 0x18(4) 0x09(5)
//   0x08(30*) 0x0D(41) 0x0E(2) 0x19(2) 0x10(2) 0x12(2)
//   0x1A(2) 0x14(4) 0x15(4) 0x16(2) 0x11(0) 0x04(70)
//   0x05(2) 0x06(14) 0x07(rest)
//
// Multi-byte field values are big-endian (firmware reads
// them via NVM_ReadField with byte | val << 8 assembly).
//------------------------------------------------

typedef struct {
    // Entry 0: NVM2_CONTROL (part_id=0x00, size=1, prot1)
    // Offset 0x000
    SetBackColor(cControl);
    ubyte   nvm2_control <format=hex, comment="NVM2 control byte (0x44 = type 0x40 active)">;

    // Entry 1: Internal partition 0x17 (size=4)
    // Offset 0x001–0x004
    SetBackColor(cInternal);
    ubyte   internal_0x17[4] <format=hex, comment="Internal partition 0x17">;

    // Entry 2: MAP_REVISION (part_id=0x01, size=1, prot1)
    // Offset 0x005
    SetBackColor(cField);
    ubyte   map_revision <format=hex, comment="MAP_REVISION (prot1)">;

    // Entry 3: POWER_STATE (part_id=0x0A, size=2, prot2: primary+mirror)
    // Offset 0x006–0x007
    // Bit 0: Power-on flag
    // Bit 1: System powered on
    // Bit 2: Abnormal shutdown (triggers recovery mode in Boot_DetermineBootMode)
    // Bit 4: Debug mode
    // Bit 5: Boot attempted (set by NVM_SetBootAttemptedFlag before kernel launch)
    SetBackColor(cMirror);
    struct POWER_STATE_FIELD {
        ubyte primary <format=hex, comment="bit0=power-on, bit1=powered, bit2=abnormal shutdown→recovery, bit4=debug, bit5=boot attempted">;
        ubyte mirror  <format=hex, comment="Power state mirror (primary XOR 0xFF)">;
    } power_state <comment="POWER_STATE (prot2: primary+mirror)">;

    // Entry 4: Internal partition 0x18 (size=4)
    // Offset 0x008–0x00B
    SetBackColor(cInternal);
    ubyte   internal_0x18[4] <format=hex, comment="Internal partition 0x18">;

    // Entry 5: BOARD_ID (part_id=0x09, size=5, prot0: 2B primary + 2B mirror + 1B checksum)
    // Offset 0x00C–0x010
    SetBackColor(cField);
    struct BOARD_ID_FIELD {
        ubyte   primary[2] <format=hex, comment="Board ID primary (2 bytes, BE: 0xA284)">;
        ubyte   mirror[2]  <format=hex, comment="Board ID mirror (primary XOR 0xFF)">;
        ubyte   checksum   <format=hex, comment="Board ID checksum (prot0)">;
    } board_id <comment="BOARD_ID (prot0: primary+mirror+checksum)">;

    // Entry 6: Dynamic gap partition 0x08 (size=30 for NVM2_CONTROL=0x44)
    // Offset 0x011–0x02E
    // Size = (lower_nibble + 3) * 4 + 2 = (4+3)*4+2 = 30
    SetBackColor(cDynGap);
    ubyte   dynamic_gap_0x08[30] <format=hex, comment="Dynamic gap (part 0x08, size=(ctrl_lo+3)*4+2=30)">;

    // Entry 7: SERIAL_NUMBER (part_id=0x0D, size=41, prot3: 20B primary + 20B mirror + 1B checksum)
    // Offset 0x02F–0x057
    SetBackColor(cSerial);
    struct SERIAL_NUMBER_FIELD {
        char    primary[20]  <comment="Serial number primary (20 bytes, ASCII padded with zeros)">;
        ubyte   mirror[20]   <format=hex, comment="Serial number mirror (each byte XOR 0xFF)">;
        ubyte   checksum     <format=hex, comment="Serial number checksum (prot3)">;
    } serial_number <comment="SERIAL_NUMBER (prot3: primary+mirror+checksum)">;

    // Entry 8: BOOT_FLAGS (part_id=0x0E, size=2, prot2: primary+mirror)
    // Offset 0x058–0x059
    // Bit 0: Power-on pending (cleared by UI_HandleBootMenu on next boot)
    // Bit 1: Recovery mode (set by NVM_SetRecoveryMode, cleared by NVM_ClearRecoveryMode)
    //        → checked by NVM_CheckRecoveryFlags → forces Recovery Partition boot
    // Bit 2: Bad updatable partition (set by Boot_SetRecoveryAndReset on OTP fail)
    // Bit 5: Cleared by Boot_ValidateAndLaunch (1st-stage) after successful image launch
    // Bit 6: One-time recovery (set by NVM_SetOneTimeRecoveryBit; cleared after single recovery boot)
    // Bit 7: NVM initialized — factory-set, never written by production firmware
    SetBackColor(cMirror);
    struct BOOT_FLAGS_FIELD {
        ubyte primary <format=hex, comment="bit0=pwr-on pending, bit1=recovery, bit2=bad updatable, bit5=validated, bit6=one-time recy, bit7=NVM init (factory)">;
        ubyte mirror  <format=hex, comment="Boot flags mirror (primary XOR 0xFF)">;
    } boot_flags <comment="BOOT_FLAGS (prot2: primary+mirror)">;

    // Entry 9: Internal partition 0x19 (size=2)
    // Offset 0x05A–0x05B
    SetBackColor(cInternal);
    ubyte   internal_0x19[2] <format=hex, comment="Internal partition 0x19">;

    // Entry 10: BOOT_FLAGS3 (part_id=0x10, size=2, prot2: primary+mirror)
    // Offset 0x05C–0x05D
    // Bit 7: One-time recovery clear (checked by Boot_ClearOneTimeRecoveryFlag in first-stage)
    // 0xFF/0xFF = uninitialized (mirror validation fails → treated as 0)
    SetBackColor(cMirror);
    struct BOOT_FLAGS3_FIELD {
        ubyte primary <format=hex, comment="bit7=one-time recovery clear; 0xFF=uninitialized">;
        ubyte mirror  <format=hex, comment="Boot flags 3 mirror (primary XOR 0xFF)">;
    } boot_flags3 <comment="BOOT_FLAGS3 (prot2, uninitialized=0xFF/0xFF)">;

    // Entry 11: POWER_STATE2 (part_id=0x12, size=2, prot2: primary+mirror)
    // Offset 0x05E–0x05F
    // Bit 1: Recovery flag (checked by NVM_IsRecoveryFlagSet; read early in
    //        Boot_DetermineBootMode → overrides boot mode to 0x1D=recovery)
    // Bit 2: Bad updatable partition marker (set when NAND_LoadLBIPartition fails)
    // 0xFF/0xFF = uninitialized (mirror validation fails → treated as 0)
    SetBackColor(cMirror);
    struct POWER_STATE2_FIELD {
        ubyte primary <format=hex, comment="bit1=recovery flag, bit2=bad updatable partition; 0xFF=uninitialized">;
        ubyte mirror  <format=hex, comment="Power state 2 mirror (primary XOR 0xFF)">;
    } power_state2 <comment="POWER_STATE2 (prot2, uninitialized=0xFF/0xFF)">;

    // Entry 12: Internal partition 0x1A (size=2)
    // Offset 0x060–0x061
    SetBackColor(cInternal);
    ubyte   internal_0x1A[2] <format=hex, comment="Internal partition 0x1A">;

    // Entry 13: ASSERT_SEQ_NUM (part_id=0x14, size=4, prot1)
    // Offset 0x062–0x065
    // NOTE: Multi-byte value, firmware reads as big-endian
    SetBackColor(cField);
    ubyte   assert_seq_num[4] <format=hex, comment="ASSERT_SEQ_NUM (prot1, 4 bytes BE)">;

    // Entry 14: PSKU_CONFIG (part_id=0x15, size=4, prot1)
    // Offset 0x066–0x069
    // 32-bit big-endian value with overlapping bit-field interpretations:
    //   Bits [31:24]  top_byte       — Chip/board ID (0x2A=Dune, 0x29=Selene). In merge mode B, NVM-controlled.
    //   Bits [16:15]  config_type_b  — Merge selector B (non-zero=active; NVM controls bits 31:24 + 16:15)
    //   Bits [14:13]  config_type_a  — Merge selector A (non-zero=active; NVM controls bits 7:0 + 14:13)
    //                                  Also: feature bits 6:5 (inverted) in the feature-flag API
    //   Bits [12:11]  sku_level      — SKU access level: 0=unconfigured, 1=level 1, 3=level 3
    //                                  Also: feature bits 4:3 (inverted) in the feature-flag API
    //   Bits [14:8]   ~feature[6:0]  — Feature flags (INVERTED: 0=enabled, 1=disabled)
    //       feature 0 (bit  8): (unknown)
    //       feature 1 (bit  9): (unknown)
    //       feature 2 (bit 10): (unknown; when enabled, implies feature 4)
    //       feature 3 (bit 11): (unknown)
    //       feature 4 (bit 12): RTC presence — adds "rtc" property to /product DTB node
    //       feature 5 (bit 13): NOS_PSKU_FEATURE_DB_UI — display panel: 0=Luna-Mid, 1=Luna-Low
    //       feature 6 (bit 14): Persistence lock — prevents PSKU from being cleared on panel detect
    //   Bits [7:0]    flags_byte     — PSKU flags. Used for panel configuration matching. In merge mode A, NVM-controlled.
    // Sample: 0x2A008442 → top=0x2A(Dune), config_b=01(active), features: RTC+Mid+Lock, flags=0x42
    SetBackColor(cField);
    ubyte   psku_config[4] <format=hex, comment="PSKU_CONFIG (prot1, 4 bytes BE) — see bit-field comments above">;

    // Entry 15: EEPROM_RECOV_COUNT (part_id=0x16, size=2, prot1)
    // Offset 0x06A–0x06B
    SetBackColor(cField);
    ubyte   eeprom_recov_count[2] <format=hex, comment="EEPROM_RECOV_COUNT (prot1, 2 bytes BE)">;

    // Entry 16: Boundary marker (part_id=0x11, size=0)
    // No bytes — just marks transition to counter partitions at 0x06C

    // Entry 17: Counter_Data (part_id=0x04, size=70)
    // Offset 0x06C–0x0B1 — Circular crash/panic log
    // 5 slots × 14 bytes each. Written by bootloader panic dispatch
    // (NVM_InitCounterPartition → FUN_9ff1a10a callback).
    // Record format: [4B crash_code][2B error_code][4B detail][4B timestamp]
    //   Assert:        crash_code = CRC16(filename\0) | (assert_code << 16)
    //   PanicWithCode: crash_code = caller-defined
    //   detail:        source filename pointer (bootloader RAM) or context
    //   timestamp:     hardware timer value (0 if not yet initialized)
    SetBackColor(cCounter);
    BigEndian();  // Bootloader is BE8 — crash records stored big-endian
    struct CRASH_RECORD {
        uint    crash_code <format=hex, comment="Assert: CRC16(file\\0) | (code<<16); PanicWithCode: caller-defined">;
        ushort  error_code <format=hex, comment="Severity/category code">;
        uint    detail     <format=hex, comment="Source filename pointer (bootloader RAM) or context">;
        uint    timestamp  <format=hex, comment="Hardware timer value (0 = not initialized)">;
    } crash_log[5] <comment="Crash/panic log: 5-slot circular buffer of 14-byte records">;
    LittleEndian();  // Restore for remaining fields

    // Entry 18: Counter_State (part_id=0x05, size=2)
    // Offset 0x0B2–0x0B3
    // Byte[0]: bits[6:0] = current write index (0-4), bit[7] = bank flag
    // Byte[1]: XOR checksum of all 70 Counter_Data bytes
    // On init: if checksum mismatch → resets all counter data to 0 on next crash
    SetBackColor(cCounter);
    struct COUNTER_STATE {
        ubyte   index_bank <format=hex, comment="bits[6:0]=write index (0-4), bit[7]=bank flag">;
        ubyte   xor_checksum <format=hex, comment="XOR of all 70 Counter_Data bytes">;
    } counter_state <comment="Counter state: write index + integrity checksum">;

    // Entry 19: Counter_Config (part_id=0x06, size=14)
    // Offset 0x0B4–0x0C1 — Reserved/unused (0xFF fill in both dumps)
    SetBackColor(cCounter);
    ubyte   counter_config[14] <format=hex, comment="Counter config (reserved, all 0xFF)">;

    // Entry 20: Remaining_Space (part_id=0x07, size=rest)
    // Offset 0x0C2–0x0FF
    SetBackColor(cPadding);
    ubyte   remaining[62] <format=hex, comment="Remaining partition space (0xFF fill)">;

} NVM_PARTITIONED_FIELDS <comment="NVM partitioned field region (0x000-0x0FF, type 0x40 layout)">;

//------------------------------------------------
// SECTION 2: Flat NVM Fields (0x100–0x130)
// 13 fields, contiguous, accessed via flat table
// (partition_id > 0x80). 49 bytes total; the byte
// at 0x131 belongs to Section 3 (NOS NVM extension).
//------------------------------------------------

typedef struct {
    // 0x100: MAP2_VERSION (field_id=0x10, pid=0x81, sz=2, prot=1)
    ushort  map2_version <format=hex, comment="NVM map version 2", bgcolor=cFlatField>;

    // 0x102: PcaSerialNumber (field_id=0x11, pid=0x82, sz=10, prot=1)
    char    pca_serial_number[10] <comment="PCA serial number (NVM field)", bgcolor=cSerial>;

    // 0x10C: ETH0_MAC_ADDR (field_id=0x12, pid=0x83, sz=6, prot=1)
    ubyte   eth0_mac[6] <format=hex, comment="Ethernet MAC address", bgcolor=cMAC>;

    // 0x112: WLAN0_MAC_ADDR (field_id=0x13, pid=0x84, sz=6, prot=1)
    ubyte   wlan0_mac[6] <format=hex, comment="WLAN0 MAC address", bgcolor=cMAC>;

    // 0x118: WLAN1_MAC_ADDR (field_id=0x14, pid=0x85, sz=6, prot=1)
    ubyte   wlan1_mac[6] <format=hex, comment="WLAN1 MAC address", bgcolor=cMAC>;

    // 0x11E: POWER_CYCLE_COUNT (field_id=0x15, pid=0x86, sz=2, prot=1)
    // NVM_ReadField/WriteField use big-endian for ALL fields (flat + partitioned).
    // Confirmed: read loop = uVar5 = *pbVar1 | uVar5 << 8
    //            write loop = local_1c[i] = param >> (remaining * 8)
    BigEndian();
    ushort  power_cycle_count <comment="Power cycle count (BE — all NVM fields are BE)", bgcolor=cFlatField>;
    LittleEndian();

    // 0x120: SECURE_VARS (field_id=0x16, pid=0x87, sz=1, prot=1)
    // Bit 2: Purpose TBD (set in both dumps; not read by any known bootloader function)
    // Bit 7: Software Secure Boot override (2nd-stage TZ_CheckSecureBootFuse)
    //         NOTE: This is NOT the primary Secure Boot control.
    //         The primary control is the SoC hardware security fuse at 0x3C001048
    //         (TZ_ReadSecurityFuse → TZ_IsSecureBootEnabled). The HW fuse propagates
    //         through first-stage authentication → code integrity check, making
    //         Secure Boot active even when this bit is clear.
    ubyte   secure_vars <format=hex, comment="bit2=TBD, bit7=SW Secure Boot override (HW fuse at 0x3C001048 is primary)", bgcolor=cFlatField>;

    // 0x121: BOOT_FLAGS2 (field_id=0x17, pid=0x88, sz=2, prot=1)
    // Bit 2:  Updatable partition failed (1st-stage Boot_MarkPartitionFailed, magic==0x1A5A5A5A)
    // Bit 3:  Recovery mode set (written by NVM_SetRecoveryMode; persistent record)
    // Bit 4:  Recovery partition failed (1st-stage Boot_MarkPartitionFailed, magic!=0x1A5A5A5A)
    // Bit 5:  Recovery mode cleared (written by NVM_ClearRecoveryMode)
    // Bit 8:  UI boot mode 0x20 (written by UI_BootSubMenuInput)
    // Bit 9:  UI boot mode 0x21 (written by UI_BootSubMenuInput)
    // Bit 12: Factory reset requested (written by Boot_SetFactoryResetFlagAndReboot)
    BigEndian();
    ushort  boot_flags2 <format=hex, comment="bit2=updatable failed, bit3=recovery set, bit4=recovery failed, bit5=recovery cleared, bit8/9=UI boot mode, bit12=factory reset (BE)", bgcolor=cFlatField>;
    LittleEndian();

    // 0x123: MISC_1 (field_id=0x18, pid=0x89, sz=4, prot=1)
    uint    misc_1 <format=hex, comment="Miscellaneous field 1 (0xFFFFFFFF = empty)", bgcolor=cFlatField>;

    // 0x127: SAVE_RECOVER_ID (field_id=0x19, pid=0x90, sz=4, prot=1)
    uint    save_recover_id <format=hex, comment="Save/recover identifier (0xFFFFFFFF = empty)", bgcolor=cFlatField>;

    // 0x12B: MPCA_BPCA_PAIRING (field_id=0x1A, pid=0x91, sz=1, prot=2)
    struct MPCA_BPCA_PAIR {
        ubyte primary <format=hex, comment="MPCA/BPCA pairing primary">;
        ubyte mirror  <format=hex, comment="MPCA/BPCA pairing mirror (XOR 0xFF)">;
    } mpca_bpca_pairing <comment="MPCA/BPCA pairing (prot=2: mirror)", bgcolor=cMirror>;

    // 0x12D: MISC_2 (field_id=0x1B, pid=0x92, sz=2, prot=1)
    ushort  misc_2 <format=hex, comment="Miscellaneous field 2 (0xFFFF = empty)", bgcolor=cFlatField>;

    // 0x12F: UNKNOWN_1C (field_id=0x1C, pid=0x93, sz=2, prot=1)
    ushort  unknown_1c <format=hex, comment="Unknown field 0x1C", bgcolor=cFlatField>;
} FLAT_NVM_FIELDS <comment="Flat NVM fields (0x100-0x130, 13 entries, 49 bytes)">;

//------------------------------------------------
// SECTION 3: NOS NVM Extension (0x131–0x1FD)
//
// Bytes that are part of the NOS region but NOT in
// the bootloader's flat table. Accessed by the
// userspace NOS NVM system (libNvram.so) using its
// own NOS NVM IDs — the bootloader neither reads
// nor writes them.
//
// 0x131-0x134: BackupDevicePin (NOS NVM ID 0x94,
//   4 bytes). Firmware treats this as a little-
//   endian integer in RAM; the firmware-toolkit
//   sidecar stores it as a hex string in on-disk
//   byte order (so "0xFFFFFFFF" when unprogrammed).
//   See HP_Dune_Selene_PIN_Analysis.md §8.3.
// 0x135:        Flat-cache tail byte (end of the
//   bootloader's 0x000-0x135 cached span).
// 0x136-0x1FD:  0xFF-filled unused filler between
//   the NOS region and the NVM2 root-page pointer.
//
// The last two ranges (0x135-0x1FD, 201 bytes) are
// modelled as a single opaque "nos_nvm_reserved"
// field in the firmware-toolkit sidecar — preserved
// verbatim so any device-specific state round-trips.
//------------------------------------------------

typedef struct {
    ubyte   backup_device_pin[4] <format=hex,
        comment="BackupDevicePin (NOS NVM ID 0x94, 4 B on-disk-LE). Sidecar representation: hex string \"0xAABBCCDD\" in on-disk byte order — byte-reverse to recover the logical LE integer.",
        bgcolor=cNosNvmExt>;
    ubyte   nos_nvm_reserved[201] <format=hex,
        comment="Opaque filler: flat-cache tail byte @ 0x135 + 0xFF-filled gap 0x136-0x1FD. Preserved verbatim.",
        bgcolor=cNosNvmExt>;
} NOS_NVM_EXTENSION <comment="NOS NVM extension (0x131-0x1FD, tier-3 userspace-only NOS fields)">;

//------------------------------------------------
// SECTION 4: Root Page Pointer (0x1FE–0x1FF)
// Big-endian uint16, written by _write_root_page()
// Points to start of NVM2 metadata (page 8 = 0x200)
//
// NOTE: The firmware-toolkit plugin models these 2
// bytes as part of the NVM2 region (nvm2_region.bin
// starts at 0x01FE and exposes root_page_pointer in
// nvm2_layout.json), not as part of the NOS region.
//------------------------------------------------

typedef struct {
    BigEndian();
    ushort  root_page_ptr <format=hex, comment="Root page pointer (BE, page 8 = 0x0008 * 64 = 0x200)">;
    LittleEndian();
} ROOT_PAGE_PTR <comment="NVM2 root page pointer (0x1FE-0x1FF, big-endian)">;

//------------------------------------------------
// SECTION 5: NVM2 Header (0x200–0x212)
//
// Written by _write_root_page() and _format_nvm()
// in the kernel NVM driver. Total 19 bytes (including
// the root page pointer at 0x1FE).
//
// Fields decoded from kernel decompilation:
//   _format_nvm: writes magic, version_info, counts,
//     bitmap offsets, debug level, generation counter
//   _nvm_build_table: reads object_count, max_objects,
//     bitmap offsets to build object table
//------------------------------------------------

typedef struct {
    // 0x200: Magic signature (LE uint32)
    uint    magic <format=hex, comment="NVM2 magic: 0x7EEDC0DE">;

    // 0x204: version_info = (key_id << 16) | version (LE uint32)
    // key_id from device tree hp_key_id (value 1), version = 2
    uint    version_info <format=hex, comment="(key_id << 16) | version = 0x00010002">;

    // 0x208: Current object count (LE uint16)
    // Incremented by _create_object, decremented by _delete_object
    ushort  object_count <comment="Active NVM object count (268 old, 291 new)">;

    // 0x20A: Max objects capacity (LE uint16)
    ushort  max_objects <comment="Max object table capacity (300)">;

    // 0x20C: Allocation bitmap EEPROM offset (LE uint16)
    ushort  alloc_bitmap_offset <format=hex, comment="Allocation bitmap offset (0x0280 = page 10)">;

    // 0x20E: Span bitmap EEPROM offset (LE uint16)
    ushort  span_bitmap_offset <format=hex, comment="Span bitmap offset (0x0240 = page 9)">;

    // 0x210: Debug level (uint8)
    ubyte   debug_level <format=hex, comment="Debug verbosity (0xFF = disabled)">;

    // 0x211: Generation / recovery counter (LE uint16)
    //        a.k.a. "format_count" in NVM2_Write_Path.md.
    //        Bumped only by _format_nvm(); read by detectSelfRecoveryCount()
    //        and by RedundancyNvramEEPROM::doValidateOperate (the sole
    //        arbiter between live EEPROM and /mnt/rw/backups/eeprom.bak).
    //        Mirrored in NOS Tier-1 as EEPROM_RECOV_COUNT at 0x06A-0x06B.
    ushort  format_count <comment="format_count / generation_counter / eeprom_recovery_count (bumped only by _format_nvm)">;

} NVM2_HEADER <comment="NVM2 header (0x200-0x212, 19 bytes)">;

//------------------------------------------------
// Padding between header end (0x213) and span
// bitmap (0x240)
//------------------------------------------------

typedef struct {
    ubyte padding[0x240 - 0x213] <format=hex>;
} NVM2_HEADER_PADDING <comment="NVM2 header padding (0x213-0x23F, 0xFF fill)">;

//------------------------------------------------
// SECTION 6: Page Bitmaps (0x240–0x2BF)
//
// Two 64-byte bitmaps maintained by the kernel NVM
// driver. Each bit corresponds to one 64-byte page
// (bit 0 of byte 0 = page 0, etc.).
//
// Set by _nvm_allocate() via _set_bit().
//------------------------------------------------

typedef struct {
    // Each bit = 1 page. 64 bytes = 512 bits = 512 pages
    ubyte   bits[64] <format=hex, comment="Page bitmap (bit N = page N)">;
} PAGE_BITMAP;

//------------------------------------------------
// NVM Variable Name Lookup
//
// Derived from libNvram.so 0x5fe4c..0x68000 (v=2,
// 2618 entries) + 48-entry descriptor table at
// 0x5fa90..0x5fe50 (v!=2 entries).
//
// Key = (vendor_id << 16) | name_id  == NVM_OBJECT.obj_id
//
// Used by ReadNVMObject() to display human-readable
// names instead of raw IDs, making known plaintext
// cribs obvious in the Template Results pane.
//------------------------------------------------

string LookupNVMName(uint vendor, uint name_id) {
    // Build a 22-bit composite key: (vendor << 16) | name_id
    uint key = ((vendor & 0xFF) << 16) | (name_id & 0xFFFF);
    switch (key) {
        case 0x010000: return "NVM2_CONTROL";
        case 0x010005: return "POWER_STATE";
        case 0x010006: return "BOARD_ID";
        case 0x010011: return "MFG_ICT_DS_1";
        case 0x01001e: return "SerialNumber";
        case 0x010048: return "BOOT_FLAGS2";
        case 0x01004e: return "CLOCK_OFFSET";
        case 0x010058: return "BOOT_FLAGS2";
        case 0x01005e: return "CLOCK_OFFSET";
        case 0x010120: return "MISC_BITS_1";
        case 0x01012b: return "MISC_BITS_2";
        case 0x020001: return "CfgRuntimeProduct";
        case 0x020002: return "CfgProto";
        case 0x020003: return "eEngineDataTest1";
        case 0x020004: return "eCPRNumberOfRetries";
        case 0x020005: return "eDHalfSensorValuesValid_FullSpeed_Yellow";
        case 0x020006: return "eDHalfSensorValuesValid_FullSpeed_Magenta";
        case 0x020007: return "eDHalfSensorValuesValid_FullSpeed_Cyan";
        case 0x020008: return "eDHalfSensorValuesValid_FullSpeed_Black";
        case 0x020009: return "eCalibrationEnvironmentStatus";
        case 0x02000a: return "ePrintDensitySensorValuesYellow";
        case 0x02000b: return "ePrintDensitySensorValuesMagenta";
        case 0x02000c: return "ePrintDensitySensorValuesCyan";
        case 0x02000d: return "ePrintDensitySensorValuesBlack";
        case 0x02000e: return "eCPRTopMarginOffsetPlane1";
        case 0x02000f: return "eCPRTopMarginOffsetPlane2";
        case 0x020010: return "eCPRTopMarginOffsetPlane3";
        case 0x020011: return "eCPRTopMarginOffsetPlane4";
